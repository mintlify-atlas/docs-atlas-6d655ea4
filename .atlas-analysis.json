  "keyFeatures": [
    "Reactive microservices architecture with Spring WebFlux and R2DBC",
    "JWT-based authentication with role-based access control (Admin, Property Owner, User)",
    "Motel management with approval workflow (Pending, Under Review, Approved, Rejected)",
    "Room and service catalog with availability checking",
    "Reservation lifecycle management (create, confirm, check-in, check-out, cancel)",
    "MercadoPago payment integration with OAuth and webhook support",
    "Email notification service for reservation and payment events",
    "API Gateway with JWT validation and route-based authorization",
    "Cloudinary image upload for motel photos",
    "Angular PWA frontend with geolocation and map integration"
  ],
